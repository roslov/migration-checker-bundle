{
    "name": "roslov/migration-checker-bundle",
    "type": "symfony-bundle",
    "description": "Up/down database migration checker for Symfony",
    "keywords": [
        "migration",
        "database",
        "up",
        "down",
        "Symfony",
        "bundle",
        "dev"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Oleksandr Roslov",
            "email": "tr2003@gmail.com"
        }
    ],
    "prefer-stable": true,
    "require": {
        "php": "^8.1",
        "doctrine/migrations": "^3.6",
        "doctrine/orm": "^2.0|^3.0",
        "roslov/migration-checker": "^0.2.7",
        "sebastian/diff": "^5.0|^6.0|^7.0|^8.0",
        "symfony/config": "^6.0|^7.0|^8.0",
        "symfony/dependency-injection": "^6.0|^7.0|^8.0",
        "symfony/framework-bundle": "^6.0|^7.0|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "roslov/psr12ext": "^14.1"
    },
    "autoload": {
        "psr-4": {
            "Roslov\\MigrationCheckerBundle\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Roslov\\MigrationCheckerBundle\\Tests\\": "tests"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "infection/extension-installer": true,
            "composer/package-versions-deprecated": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "support": {
        "source": "https://github.com/roslov/migration-checker-bundle"
    }
}
